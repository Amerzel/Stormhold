; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via a script.

[application]

config/name="Stormhold"
config/description="Single-zone ARPG vertical slice built with Forge tools"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4")
config/icon="res://icon.svg"

[autoload]

GameData="*res://scripts/managers/game_data.gd"
CombatManager="*res://scripts/managers/combat_manager.gd"
QuestManager="*res://scripts/managers/quest_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="viewport"
window/stretch/aspect="expand"

